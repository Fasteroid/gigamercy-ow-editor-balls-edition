rule("Create HUD Instruction Text")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		"Separator from top of screen (default 22 new lines)"
		Create HUD Text(All Players(All Teams), Null, Null, Custom String("\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"), Top, 20, Null,
			Null, Null, Visible To and String, Default Visibility);
		"Option 1: Large size Hint text with border"
		Create HUD Text(Global.HintTexts[Local Player.Checkpoint] != Null && String Length(Global.HintTexts[Local Player.Checkpoint])
			> 0 ? Local Player : Null, Custom String(" {0} : {1} ", Hero Icon String(Hero Of(Local Player.Bot)),
			Global.HintTexts[Local Player.Checkpoint]), Null, Null, Top, 23, Global.Settings[23], Null, Null, Visible To String and Color,
			Default Visibility);
		"Option 2: Medium size Hint text without border"
		disabled Create HUD Text(Global.HintTexts[Local Player.Checkpoint] ? Local Player : Null, Null, Null, Custom String("{0} : {1}",
			Hero Icon String(Hero Of(Local Player.Bot)), Global.HintTexts[Local Player.Checkpoint]), Top, 23, Null, Null,
			Global.Settings[23], Visible To String and Color, Default Visibility);
	}
}

rule("——————————————————— Parkour Engine rules ———————————————————")
{
	event
	{
		Ongoing - Global;
	}
}

rule("Detect Leaving Checkpoint")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.Finished == False;
		Event Player.FreeMode == False;
		Event Player.LeftCheckpoint == False;
		Distance Between(Event Player, Global.Checkpoints[Event Player.Checkpoint][0]) > Global.Checkpoints[Event Player.Checkpoint][1];
	}

	actions
	{
		Event Player.LeftCheckpoint = True;
		Abort If(Event Player.Cheat);
		Chase Player Variable At Rate(Event Player, CurrentRunTime, 20000, 1, Destination and Rate);
	}
}

rule("Detect Landing Outside")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.GoalCoords != Null;
		Event Player.FreeMode == False;
		Event Player.Finished == False;
		Event Player.LeftCheckpoint == True;
		Is On Ground(Event Player) == True;
	}

	actions
	{
		"Free walking"
		Abort If(Global.Checkpoints[Event Player.Checkpoint][5]);
		Skip If(Hero Of(Event Player) == Hero(Mercy), 2);
		Wait Until(Is Using Ability 1(Event Player) == False, 9999);
		Abort If(!Is On Ground(Event Player));
		Log To Inspector(Custom String("{0} - Landed outside the goal", Event Player));
		Abort If(Distance Between(Event Player, Event Player.GoalCoords) <= Event Player.GoalRadius && (Y Component Of(Position Of(
			Event Player)) <= Y Component Of(Event Player.GoalCoords) + Event Player.GoalThresholds[0] && Y Component Of(Position Of(
			Event Player)) >= Y Component Of(Event Player.GoalCoords) - Event Player.GoalThresholds[1]) == True);
		If(Distance Between(Event Player, Global.Checkpoints[Event Player.Checkpoint][0])
			< Global.Checkpoints[Event Player.Checkpoint][1]);
			Call Subroutine(ResetCheckpoint);
		Else;
			Call Subroutine(ResetWithMistake);
		End;
	}
}

rule("Detect Landing on Goal or Teleport")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.Finished == False;
		Event Player.FreeMode == False;
		Event Player.LeftCheckpoint == True;
		"// TODO: Get OnGround flag from current goal in case the level has a teleport"
		((Global.Checkpoints[Event Player.Checkpoint + 1][4] && Is On Ground(Event Player))
			|| !Global.Checkpoints[Event Player.Checkpoint + 1][4]) == True;
		Distance Between(Event Player, Event Player.GoalCoords) <= Event Player.GoalRadius;
		(Y Component Of(Position Of(Event Player)) <= Y Component Of(Event Player.GoalCoords)
			+ Event Player.GoalThresholds[0] && Y Component Of(Position Of(Event Player)) >= Y Component Of(Event Player.GoalCoords)
			- Event Player.GoalThresholds[1]) == True;
	}

	actions
	{
		If(Is True For Any(Event Player.GrabbedOrbs, Current Array Element == False) && Count Of(Event Player.GrabbedOrbs) > 0);
			Small Message(Event Player, Custom String("  You need to grab all orbs!"));
			Play Effect(Event Player, Debuff Impact Sound, Null, Event Player, 100);
			Call Subroutine(ResetWithMistake);
		Else If(Is True For Any(Event Player.GrabbedRefreshOrbs, Current Array Element == False) && Count Of(
				Event Player.GrabbedRefreshOrbs) > 0 && Global.RequireGrabAllRefreshOrbs);
			Small Message(Event Player, Custom String("  You need to grab all refresh orbs!"));
			Play Effect(Event Player, Debuff Impact Sound, Null, Event Player, 100);
			Call Subroutine(ResetWithMistake);
		Else If(Global.Bots[Event Player.Checkpoint] && !Event Player.BotCondition);
			Small Message(Event Player, Custom String("  You need to rez the bot!"));
			Play Effect(Event Player, Debuff Impact Sound, Null, Event Player, 100);
			Call Subroutine(ResetWithMistake);
		"TODO: Support multiple teleports and custom TP position. We assume teleports only get us to the next level for now"
		Else If(Global.Teleports[Event Player.Checkpoint][2]);
			"This feature not implemented in this revision, but we getting there"
			Abort;
			"Teleport player to a position within the same checkpoint"
			Teleport(Event Player, Global.Teleports[Event Player.Checkpoint][2]);
			Play Effect(Event Player, Sombra Translocator Reappear Sound, Null, Position Of(Event Player), 100);
		Else;
			Event Player.Checkpoint += 1;
			"Player finished all checkpoints"
			If(Event Player.Checkpoint == Count Of(Global.Checkpoints) - 1);
				Stop Chasing Player Variable(Event Player, CurrentRunTime);
				Event Player.FreeMode = True;
				"// TODO: Consider not duplicating this block if possible"
				If(Global.Teleports[Event Player.Checkpoint - 1]);
					Call Subroutine(TeleportToCurrentCheckpoint);
					Play Effect(Event Player, Sombra Translocator Reappear Sound, Null, Position Of(Event Player), 100);
				End;
				disabled Call Subroutine(EnableAllAbilities);
				Play Effect(All Players(All Teams), Ring Explosion Sound, Null, Event Player, 100);
				"// TODO: Set a color for finish explosion in config"
				Play Effect(All Players(All Teams), Good Pickup Effect, Color(Aqua), Global.Checkpoints[Event Player.Checkpoint][0],
					Global.Checkpoints[Event Player.Checkpoint][1]);
				"disabled to avoid the 0s scoreboard exploit"
				disabled Wait(0.100, Ignore Condition);
				Skip If(Event Player.Cheat || Global.EditMode, 2);
				Big Message(All Players(All Teams), Custom String("{0} Finished in {1} seconds", Event Player.Nickname,
					Event Player.CurrentRunTime));
				Call Subroutine(PlayerCompletedRun);
			"Player arrived at a teleport"
			Else If(Global.Teleports[Event Player.Checkpoint - 1]);
				"// TODO: This broke jazzy's hanamura lvl 98 to 99, it cancels momentum so for now we teleport the player manually"
				disabled Call Subroutine(TeleportToCurrentCheckpoint);
				Call Subroutine(CancelMomentum);
				Teleport(Event Player, Global.Checkpoints[Event Player.Checkpoint][0]);
			End;
			Play Effect(Event Player, Buff Explosion Sound, Null, Event Player, 100);
			Call Subroutine(SetUpCheckpoint);
			Call Subroutine(SavePlayerProgress);
		End;
	}
}

rule("Detect Grabbing Orb v2")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.Finished == False;
		Event Player.FreeMode == False;
		Count Of(Global.Orbs[Event Player.Checkpoint]) > 0;
		Is True For Any(Global.Orbs[Event Player.Checkpoint], !Event Player.GrabbedOrbs[Current Array Index] && (Distance Between(
			Position Of(Event Player) + Vector(0, 0.700, 0), Current Array Element[0])
			<= 0.700 + Current Array Element[1] || Distance Between(Eye Position(Event Player), Current Array Element[0])
			<= 0.700 + Current Array Element[1])) == True;
	}

	actions
	{
		disabled Log To Inspector(Custom String("{0} - Grabbed Orb", Event Player));
		If(Event Player.BotCondition);
			Event Player.GrabbedOrbs = Mapped Array(Global.Orbs[Event Player.Checkpoint],
				Event Player.GrabbedOrbs[Current Array Index] || Distance Between(Position Of(Event Player) + Vector(0, 0.700, 0),
				Current Array Element[0]) <= 0.700 + Current Array Element[1] || Distance Between(Eye Position(Event Player),
				Current Array Element[0]) <= 0.700 + Current Array Element[1] ? True : False);
			Small Message(Event Player, Custom String("  Orb Grab! {0}/{1}", Count Of(Filtered Array(Append To Array(Event Player.GrabbedOrbs,
				Global.RequireGrabAllRefreshOrbs ? Event Player.GrabbedRefreshOrbs : Empty Array), Current Array Element == True)), Count Of(
				Event Player.GrabbedOrbs) + (Global.RequireGrabAllRefreshOrbs ? Count Of(Event Player.GrabbedRefreshOrbs) : 0)));
			Play Effect(Event Player, Buff Impact Sound, Null, Event Player, 100);
		Else;
			Small Message(Event Player, Custom String("  You need to rez the bot!"));
			Play Effect(Event Player, Debuff Impact Sound, Null, Event Player, 100);
			Call Subroutine(ResetWithMistake);
		End;
	}
}

rule("Detect Grabbing RefreshOrb v2")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.Finished == False;
		Event Player.FreeMode == False;
		Count Of(Global.RefreshOrbs[Event Player.Checkpoint]) > 0;
		Is True For Any(Global.RefreshOrbs[Event Player.Checkpoint], !Event Player.GrabbedRefreshOrbs[Current Array Index] && (
			Distance Between(Position Of(Event Player) + Vector(0, 0.700, 0), Current Array Element[0])
			<= 0.700 + Current Array Element[1] || Distance Between(Eye Position(Event Player), Current Array Element[0])
			<= 0.700 + Current Array Element[1])) == True;
	}

	actions
	{
		If(Event Player.BotCondition);
			For Player Variable(Event Player, i, 0, Count Of(Event Player.GrabbedRefreshOrbs), 1);
				If(!Event Player.GrabbedRefreshOrbs[Event Player.i] && (Distance Between(Position Of(Event Player) + Vector(0, 0.700, 0),
					Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][0])
					<= Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][1] + 0.700 || Distance Between(Eye Position(Event Player),
					Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][0])
					<= Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][1] + 0.700));
					Log To Inspector(Custom String("{0} - Grabbed R.O. index {1} with section {2}", Event Player, Event Player.i,
						Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][2]));
					Event Player.GrabbedRefreshOrbs[Event Player.i] = True;
					Small Message(Event Player, Custom String("{0}Abilities refreshed: {1}", Global.RequireGrabAllRefreshOrbs ? Custom String(
						"  Orb Grab! {0}/{1}. ", Count Of(Filtered Array(Append To Array(Event Player.GrabbedOrbs,
						Global.RequireGrabAllRefreshOrbs ? Event Player.GrabbedRefreshOrbs : Empty Array), Current Array Element == True)), Count Of(
						Event Player.GrabbedOrbs) + (Global.RequireGrabAllRefreshOrbs ? Count Of(Event Player.GrabbedRefreshOrbs) : 0)) : Empty Array,
						Custom String("{0}{1}{2}", Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][3] ? Ability Icon String(Hero Of(
						Event Player), Button(Ability 1)) : Empty Array,
						Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][4] ? Ability Icon String(Hero Of(Event Player), Button(Ability 2))
						: Empty Array, Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][5] ? Ability Icon String(Hero Of(Event Player),
						Button(Ultimate)) : Empty Array)));
					Play Effect(Event Player, Buff Impact Sound, Null, Event Player, 100);
					"Trigger Bot Section"
					If(Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][2] >= 0);
						Event Player.CurrentBotSection = Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][2];
						Event Player.Bot.CurrentBotSection = Event Player.CurrentBotSection;
						"// TODO: Test to see what happens when many refresh orbs are close together"
						disabled Call Subroutine(UpdateBotPosition);
						Start Rule(UpdateBotPosition, Restart Rule);
						Event Player.BotCompletedSections[Event Player.CurrentBotSection] = True;
					End;
					Event Player.Ability1 += Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][3] ? 1 : 0;
					Set Ability 1 Enabled(Event Player, Event Player.Ability1 > 0);
					Event Player.Ability2 += Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][4] ? 1 : 0;
					Set Ability 2 Enabled(Event Player, Event Player.Ability2 > 0);
					Event Player.Ultimate = Global.RefreshOrbs[Event Player.Checkpoint][Event Player.i][5] ? True : Event Player.Ultimate;
					Set Ultimate Ability Enabled(Event Player, Event Player.Ultimate);
					Set Ultimate Charge(Event Player, Event Player.Ultimate ? 100 : 0);
					"Needed to fix small message issue with stacked orbs"
					Wait(0.016, Ignore Condition);
				End;
			End;
		Else;
			Small Message(Event Player, Custom String("  You need to rez the bot!"));
			Play Effect(Event Player, Debuff Impact Sound, Null, Event Player, 100);
			Call Subroutine(ResetWithMistake);
		End;
	}
}

rule("Detect Touching AntiOrb v2")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.Finished == False;
		Event Player.FreeMode == False;
		Global.AntiOrbs[Event Player.Checkpoint] == True;
		Is True For Any(Global.AntiOrbs[Event Player.Checkpoint], Distance Between(Position Of(Event Player) + Vector(0, 0.700, 0),
			Current Array Element[0]) <= 0.700 + Current Array Element[1] || Distance Between(Eye Position(Event Player),
			Current Array Element[0]) <= 0.700 + Current Array Element[1]) == True;
	}

	actions
	{
		Set Status(Event Player, Null, Burning, 0.160);
		Call Subroutine(ResetWithMistake);
	}
