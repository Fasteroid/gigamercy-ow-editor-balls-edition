	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Has Spawned(Event Player) == True;
		Event Player.FreeMode == True;
		Is Using Ultimate(Event Player) == False;
		Ultimate Charge Percent(Event Player) < 100;
	}

	actions
	{
		Wait(0.100, Ignore Condition);
