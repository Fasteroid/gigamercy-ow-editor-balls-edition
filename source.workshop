rule("Calculate RGB values for rainbow text")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Abort If(Global.DebugMode == True);
		While(Global.RGB[1] < 255);
			Global.RGB[1] += 3;
			Wait(0.016, Ignore Condition);
		End;
		While(Global.RGB[2] > 0);
			Global.RGB[2] -= 3;
			Wait(0.016, Ignore Condition);
		End;
		While(Global.RGB[0] < 255);
			Global.RGB[0] += 3;
			Wait(0.016, Ignore Condition);
		End;
		While(Global.RGB[1] > 0);
			Global.RGB[1] -= 3;
			Wait(0.016, Ignore Condition);
		End;
		While(Global.RGB[2] < 255);
			Global.RGB[2] += 3;
			Wait(0.016, Ignore Condition);
		End;
		While(Global.RGB[0] > 0);
			Global.RGB[0] -= 3;
			Wait(0.016, Ignore Condition);
		End;
		Loop;
	}
}

