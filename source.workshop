rule("◈ Creator and Code")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		"This rule will be ignored if you imported your map title from Taw's editor"
		Abort If(Global.MapTitle != Null);
		If(Count Of(Global.CreatorAndCode) == 0);
			"◈ Your author(s) here"
			Global.CreatorAndCode[0] = Custom String("Author");
			"◈ Your workshop code here"
			Global.CreatorAndCode[1] = Custom String("Code");
		End;
		"Only edit this if you want a custom map title"
		Global.MapTitle = Custom String("");
	}
}

