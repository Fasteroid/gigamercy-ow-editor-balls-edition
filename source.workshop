rule("Autoadvance Bot (for compatibility with Taw's editor maps)")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.LeftCheckpoint == True;
		Is True For Any(Global.RefreshOrbs[Event Player.Checkpoint], Current Array Element[2] == Event Player.CurrentBotSection + 1)
			== False;
		Event Player.BotCondition == True;
		Event Player.CurrentBotSection < Count Of(Global.Bots[Event Player.Checkpoint]) - 1;
		Ability Cooldown(Event Player, Button(Ability 1)) != 0;
	}

	actions
	{
		"This was added to be compatible with Taw's bot sections that have no refresh orb, they advance automatically after using your GA"
		Event Player.Ability1 += 1;
		Log To Inspector(Custom String("{0} - Used GA & theres no refresh orb. advancing bot now", Event Player));
		Event Player.CurrentBotSection += 1;
		Event Player.BotCompletedSections[Event Player.CurrentBotSection] = True;
		Event Player.Bot.CurrentBotSection += 1;
		Call Subroutine(UpdateBotPosition);
		Set Ability 1 Enabled(Event Player, Event Player.Ability1 > 0);
		Small Message(Event Player, Custom String("  GA {0} refreshed", Ability Icon String(Hero(Mercy), Button(Ability 1))));
	}
}

