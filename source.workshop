		"Teleport pad Text or Icon"
		Global.Settings[8] = Icon String(Spiral);
		"Player leaderboard position names"
		Global.Top5Prefix = Array(Custom String("1st"), Custom String("2nd"), Custom String("3rd"), Custom String("4th"), Custom String(
			"5th"));
		"Scoreboard title"
		Global.Settings[17] = Custom String("Scoreboard:");
		"-------Other stuff--------"
		disabled End;
		"Place to store unused bots"
		Global.BotPenCoords = Vector(0, 200, 0);
	}
