rule("BunnyHop: Mercy GA check")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Using Ability 1(Event Player) == True;
		Is Button Held(Event Player, Button(Ability 1)) == False;
	}

	actions
	{
		Event Player.GACheck = True;
		Wait Until(Is Using Ability 1(Event Player) == False, 9999);
		Event Player.GACheck = False;
	}
}

rule("BunnyHop: Using Mercy's sling/superjump loses the bhop v4")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Using Ability 1(Event Player) == True;
		Event Player.BhopActive == True;
	}

	actions
	{
		disabled Log To Inspector(Custom String("{0} - Mercy bunnyhop check", Event Player));
		Wait Until(!Is Using Ability 1(Event Player) || Evaluate Once(Is Button Held(Event Player, Button(Jump))) != Is Button Held(
			Event Player, Button(Jump)) || Evaluate Once(Is Button Held(Event Player, Button(Crouch))) != Is Button Held(Event Player,
			Button(Crouch)), 99999);
		Wait Until(!Is Using Ability 1(Event Player) || Is Button Held(Event Player, Button(Jump)) || (
			Event Player.Crouch && Is Button Held(Event Player, Button(Crouch))), 99999);
		Abort If Condition Is False;
		disabled Small Message(Event Player, Custom String("  Real GA or sling/sj detected", Event Player));
		Abort If(Is Button Held(Event Player, Button(Ability 1)) == Event Player.GACheck);
		disabled Small Message(Event Player, Custom String("  Detected a failed bhop cancel"));
		disabled Log To Inspector(Custom String("{0} - GA Used sling or sj", Event Player));
		Event Player.BhopActive = False;
	}
}

