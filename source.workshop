rule("——————————————————— Initialization Settings ———————————————————")
{
	event
	{
		Ongoing - Global;
	}
}

rule("Global Initialization")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Call Subroutine(InitializeGlobalVariables);
		Skip If(Global.DebugMode, 1);
		Disable Inspector Recording;
		Disable Built-In Game Mode Announcer;
		Disable Built-In Game Mode Completion;
		Disable Built-In Game Mode Music;
		Disable Built-In Game Mode Scoring;
		Disable Built-In Game Mode Respawning(All Players(All Teams));
		Pause Match Time;
		"Disable these if you want spawn room walls in your map (Assault/Hybrid/Escort maps only)"
		Start Forcing Spawn Room(Team 1, Color(Red));
		Start Forcing Spawn Room(Team 2, Color(Red));
		"Decompress Giga editor data"
		If(Global.MapData);
			Call Subroutine(DecompressMapData);
		"Detect Taw's Editor data"
		Else If(Global.TawsCompressedData);
			Call Subroutine(TawsDecompressData);
		"Detect Peace's Editor data. Only T6QQT is supported for now"
		Else If(Global.PeaceCheckpoint || Global.PeaceCheckpoint2);
			If(Global.PeaceCheckpoint2);
				Global.PeaceCheckpoint = Global.PeaceCheckpoint2;
				Global.PeaceCheckpoint2 = Null;
			End;
			Call Subroutine(PeaceDecompressData);
		End;
		Log To Inspector(Custom String("Decompression ended"));
		Wait(0.016, Ignore Condition);
		If(Global.EditMode);
			Call Subroutine(InitializeEditModeVariables);
			Wait(0.016, Ignore Condition);
			Call Subroutine(CreateGlobalEditModeHUD);
			Wait(0.016, Ignore Condition);
		End;
		"TEST: Cleanup empty texts to conserve memory"
		Global.WorldTexts = Mapped Array(Global.WorldTexts, String Length(Current Array Element[0]) > 0 ? Current Array Element : False);
		Global.BigMessages = Mapped Array(Global.BigMessages, String Length(Current Array Element[0]) > 0 ? Current Array Element : False);
		Wait(0.016, Ignore Condition);
		Global.SmallMessages = Mapped Array(Global.SmallMessages, String Length(Current Array Element[0])
			> 0 ? Current Array Element : False);
		Global.HintTexts = Mapped Array(Global.HintTexts, String Length(Current Array Element[0]) > 0 ? Current Array Element : Null);
		Global.VIPs = Filtered Array(Global.VIPs, String Length(Current Array Element[0]) > 0);
		Global.InitDone = True;
	}
}

rule("Player Initialization")
{
	event
	{
		Player Joined Match;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
	}

	actions
	{
		Event Player.FreeMode = True;
		Log To Inspector(Custom String("{0} - Joined match", Event Player));
		Wait Until(Has Spawned(Event Player) && Global.InitDone, 99999);
		Log To Inspector(Custom String("{0} - Initialization Start", Event Player));
		Start Forcing Player To Be Hero(Event Player, Global.Settings[11]);
		Disable Game Mode HUD(Event Player);
		Disable Game Mode In-World UI(Event Player);
		Disable Kill Feed(Event Player);
		"// TODO: Check if needed"
		Enable Death Spectate All Players(Event Player);
		Enable Death Spectate Target HUD(Event Player);
		Disable Nameplates(All Players(All Teams), Event Player);
		Disable Nameplates(Event Player, All Players(All Teams));
		Disable Movement Collision With Players(Event Player);
		Set Status(Event Player, Null, Invincible, 99999);
		Wait(0.016, Ignore Condition);
		Call Subroutine(InitializePlayerVariables);
		Call Subroutine(CreatePlayerHUD);
		If(Global.EditMode || Is True For Any(Global.Bots, Current Array Element == True));
			Call Subroutine(InitializePlayerBot);
		End;
		Wait(0.100, Ignore Condition);
		Call Subroutine(TeleportToCurrentCheckpoint);
		Event Player.FreeMode = Count Of(Global.Checkpoints) <= 0;
		Call Subroutine(SetUpCheckpoint);
		If(Global.EditMode);
			Call Subroutine(CreatePlayerEditModeHUD);
		End;
		If(Global.DebugMode == 2);
			Call Subroutine(CreatePlayerDebugModeHUD);
		End;
		Wait(0.032, Ignore Condition);
		Skip If(Global.Checkpoints[Event Player.Checkpoint][2] || !Event Player.GoalCoords, 1);
		Set Facing(Event Player, Direction Towards(Position Of(Event Player), Event Player.GoalCoords), To World);
		Start Scaling Player(Event Player, Event Player.Scale, True);
		Log To Inspector(Custom String("{0} - Initialization Done", Event Player));
	}
}

rule("————————————————————— Controls ——————————————————————")
{
	event
	{
		Ongoing - Global;
	}
}

rule("Press [Interact] twice to view/hide controls | EditMode: Open menu")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Button Held(Event Player, Button(Interact)) == True;
		Event Player.SpectatorMode == False;
	}

	actions
	{
		Abort If(Is True For Any(Remove From Array(Global.ButtonList, Array(Button(Interact), Button(Jump), Button(Crouch))),
			Is Button Held(Event Player, Current Array Element)));
		Wait Until(!Is Button Held(Event Player, Button(Interact)), 99999);
		Wait Until(Is Button Held(Event Player, Button(Interact)), 0.200);
		"These buttons create/destroy objects, we dont want to open menu during those events"
		Abort If(Is True For Any(Array(Button(Primary Fire), Button(Secondary Fire)), Is Button Held(Event Player, Current Array Element))
			|| !Is Button Held(Event Player, Button(Interact)));
		If(!Global.EditMode);
			Event Player.HideSidebarControls = !Event Player.HideSidebarControls;
			Abort;
		End;
		"For safety"
		disabled Event Player.PaletteOpen = False;
		"Fix starting abilities if the menu was closed in the middle of editing"
		Skip If(Event Player.MenuPage != 7, 2);
		Event Player.MenuPage = 0;
		Call Subroutine(GetStartingAbilities);
		Event Player.MenuPage = Event Player.ObjectType;
		Event Player.MenuOpen = !Event Player.MenuOpen;
		Event Player.EditNumber = Null;
		If(Event Player.MenuOpen);
			Set Move Speed(Event Player, 0);
			Set Jump Enabled(Event Player, False);
			Call Subroutine(GetEditTempObject);
		Else;
			Set Move Speed(Event Player, 100);
			Set Jump Enabled(Event Player, True);
		End;
		Set Primary Fire Enabled(Event Player, Event Player.MenuOpen ? False : Event Player.PrimaryFire || Event Player.FreeMode);
		Set Secondary Fire Enabled(Event Player, Event Player.MenuOpen ? False : Event Player.SecondaryFire > 0 || Event Player.FreeMode);
		Call Subroutine(GetEditMenuTempData);
	}
}

rule("Press [Interact] + [Melee] + [Primary/Secondary Fire] to switch checkpoints")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Button Held(Event Player, Button(Interact)) == True;
		Is Button Held(Event Player, Button(Melee)) == True;
		Is Button Held(Event Player, Button(Primary Fire)) != Is Button Held(Event Player, Button(Secondary Fire));
	}

	actions
	{
		Abort If(Event Player.MenuOpen);
		Skip If(Global.DebugMode > 1 || Event Player.Cheat, 4);
		Event Player.SavedCheckpoint = Event Player.Checkpoint;
		Event Player.Cheat = True;
		Stop Chasing Player Variable(Event Player, CurrentRunTime);
		Big Message(Event Player, Custom String("{0} + {1} + {2}, to continue your run", Input Binding String(Button(Interact)),
			Input Binding String(Button(Melee)), Input Binding String(Button(Ability 2))));
		Event Player.TempFreeMode = Event Player.FreeMode;
		Event Player.FreeMode = True;
		Event Player.Checkpoint = Is Button Held(Event Player, Button(Primary Fire)) ? (Event Player.Checkpoint + 1) % Count Of(
			Global.Checkpoints) : (Event Player.Checkpoint - 1 + Count Of(Global.Checkpoints)) % Count Of(Global.Checkpoints);
		If(Event Player.Cheat && Event Player.SavedCheckpoint == Event Player.Checkpoint);
			Event Player.SavedCheckpoint = Null;
			Event Player.Cheat = False;
			Small Message(Event Player, Custom String("  Exit the checkpoint to continue your time"));
		End;
		Call Subroutine(TeleportToCurrentCheckpoint);
		Event Player.FreeMode = Event Player.TempFreeMode;
		Log To Inspector(Custom String("{0} - Switched manually to CP {1}", Event Player, Event Player.Checkpoint));
		Call Subroutine(SetUpCheckpoint);
		"Hold buttons to speed switch"
		Wait(0.200, Abort When False);
		Loop If Condition Is True;
	}
}

rule("Press [Interact] + [Ability 2] + [Melee] to go back to saved Checkpoint")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.Cheat == True;
		Is Button Held(Event Player, Button(Interact)) == True;
		Is Button Held(Event Player, Button(Ability 2)) == True;
		Is Button Held(Event Player, Button(Melee)) == True;
	}

	actions
	{
		Abort If(Is True For Any(Remove From Array(Global.ButtonList, Array(Button(Interact), Button(Ability 2), Button(Melee))),
			Is Button Held(Event Player, Current Array Element)));
		Event Player.Checkpoint = Event Player.SavedCheckpoint;
		Call Subroutine(TeleportToCurrentCheckpoint);
		Call Subroutine(SetUpCheckpoint);
		Event Player.Cheat = False;
		Event Player.SavedCheckpoint = Null;
	}
}

rule("Press [Reload] to reset current checkpoint")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Button Held(Event Player, Button(Reload)) == True;
		Event Player.Finished == False;
	}

	actions
	{
		Wait(0.032, Ignore Condition);
		Wait Until(Is Button Held(Event Player, Button(Reload)) == False, 0.400);
		"Abort in case player is toggling no-clip"
		Abort If(Is Button Held(Event Player, Button(Reload)));
		Abort If(Is True For Any(Remove From Array(Global.ButtonList, Array(Button(Reload), Button(Crouch))), Is Button Held(Event Player,
			Current Array Element)));
		Call Subroutine(TeleportToCurrentCheckpoint);
		If(Event Player.LeftCheckpoint && Event Player.FreeMode == False);
			Call Subroutine(ResetWithMistake);
		Else;
			Call Subroutine(ResetCheckpoint);
		End;
	}
}

rule("Hold [Reload] in Free Mode to toggle No-Clip")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.FreeMode == True;
		Event Player.SpectatorMode == False;
		Is Button Held(Event Player, Button(Reload)) == True;
	}

	actions
	{
		Wait(1, Abort When False);
		Abort If(Is True For Any(Remove From Array(Global.ButtonList, Button(Reload)), Is Button Held(Event Player,
			Current Array Element)));
		Call Subroutine(TogglePlayerCollision);
	}
}

rule("Press [Crouch] + [Interact] + [Ability 2] to start over")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Crouch)) == True;
		Is Button Held(Event Player, Button(Interact)) == True;
		Is Button Held(Event Player, Button(Ability 2)) == True;
	}

	actions
	{
		Abort If(Event Player.MenuOpen);
		Abort If(Is True For Any(Remove From Array(Global.ButtonList, Array(Button(Crouch), Button(Interact), Button(Ability 2), Button(
			Jump))), Is Button Held(Event Player, Current Array Element)));
		Log To Inspector(Custom String("{0} - Start over", Event Player));
		Play Effect(Event Player, Tracer Recall Disappear Sound, Null, Event Player, 100);
		Event Player.Mistakes = 0;
		Event Player.FreeMode = True;
		Event Player.Cheat = False;
		Event Player.SavedCheckpoint = Null;
		If(Is Using Ultimate(Event Player));
			Call Subroutine(CancelUltimate);
		End;
		"Anti abuse measure"
		If(Event Player.Checkpoint == 0);
			Call Subroutine(TeleportToCurrentCheckpoint);
			Event Player.FreeMode = False;
			Call Subroutine(ResetCheckpoint);
		Else;
			Event Player.Checkpoint = 0;
			Call Subroutine(TeleportToCurrentCheckpoint);
			Event Player.FreeMode = False;
			Call Subroutine(SetUpCheckpoint);
		End;
		Wait(1, Ignore Condition);
	}
}

rule("Press [Reload] + [Jump] to toggle 3rd person camera")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Button Held(Event Player, Button(Reload)) == True;
		Is Button Held(Event Player, Button(Jump)) == True;
	}

	actions
	{
		Abort If(Is True For Any(Remove From Array(Global.ButtonList, Array(Button(Reload), Button(Jump))), Is Button Held(Event Player,
			Current Array Element)));
		Wait(0.200, Abort When False);
		"By overclocking"
		Event Player.ThirdPerson = !Event Player.ThirdPerson;
		Skip If(Event Player.ThirdPerson, 2);
		Stop Camera(Event Player);
		Abort;
		Start Camera(Event Player, Ray Cast Hit Position(Event Player + Up * (Distance Between(Eye Position(Event Player), Event Player)
			+ 0.500), Ray Cast Hit Position(Event Player + Up * (Distance Between(Eye Position(Event Player), Event Player) + 0.500),
			Event Player + Up * (Distance Between(Eye Position(Event Player), Event Player) + 0.500) + Facing Direction Of(Event Player)
			* -3, Null, Event Player, True), Null, Event Player, True), Event Player + Facing Direction Of(Event Player) * 100, 0);
	}
}

rule("Press [Interact] to TP to player (Free Mode only)")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.FreeMode == True;
		Is Button Held(Event Player, Button(Interact)) == True;
	}

	actions
	{
		Abort If(Is True For Any(Remove From Array(Global.ButtonList, Array(Button(Interact))), Is Button Held(Event Player,
			Current Array Element)));
		Abort If(Is Dummy Bot(Player Closest To Reticle(Event Player, All Teams)) || !Is In View Angle(Event Player,
			Player Closest To Reticle(Event Player, All Teams), 10));
		Abort If(!Is Alive(Player Closest To Reticle(Event Player, All Teams)));
		Teleport(Event Player, Player Closest To Reticle(Event Player, All Teams));
	}
}

rule("Press [Ultimate] + [Ability 2] to toggle spectator mode")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Is Button Held(Event Player, Button(Ability 2)) == True;
	}

	actions
	{
		Abort If(Event Player.MenuOpen || Is True For Any(Remove From Array(Global.ButtonList, Array(Button(Ultimate), Button(Ability 2))),
			Is Button Held(Event Player, Current Array Element)));
		Event Player.SpectatorMode = !Event Player.SpectatorMode;
		If(Event Player.SpectatorMode);
			Stop Chasing Player Variable(Event Player, CurrentRunTime);
			Event Player.LastPos = Position Of(Event Player);
			Disable Built-In Game Mode Respawning(Event Player);
			Kill(Event Player, Null);
			"TODO: Test w aeter if removing this wait keeps the body and nametag in the map"
			Wait(0.016, Ignore Condition);
			Teleport(Event Player, Vector(0, -900, 0));
		Else;
			If(Event Player.FreeMode);
				Teleport(Event Player, Event Player.LastPos);
			Else;
				Call Subroutine(TeleportToCurrentCheckpoint);
				Call Subroutine(ResetCheckpoint);
			End;
			Wait(0.016, Ignore Condition);
			Enable Built-In Game Mode Respawning(Event Player);
			Resurrect(Event Player);
		End;
		Wait(0.600, Ignore Condition);
	}
}

rule("Press [Interact] + [Reload] to toggle Free Mode")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Button Held(Event Player, Button(Interact)) == True;
		Is Button Held(Event Player, Button(Reload)) == True;
	}

	actions
	{
		Abort If((Event Player.Finished && !Global.EditMode) || Is True For Any(Remove From Array(Global.ButtonList, Array(Button(
			Interact), Button(Reload), Button(Jump), Button(Crouch))), Is Button Held(Event Player, Current Array Element)));
		If(Event Player.FreeMode);
			Skip If(Event Player.Collision, 1);
			Call Subroutine(TogglePlayerCollision);
			Call Subroutine(TeleportToCurrentCheckpoint);
			If(Is Using Ultimate(Event Player));
				Call Subroutine(CancelUltimate);
			End;
			Event Player.FreeMode = False;
			Call Subroutine(ResetCheckpoint);
		Else;
			Call Subroutine(EnableAllAbilities);
			"// TODO: Move to subroutine setcurrentabilities?"
			Event Player.FreeMode = True;
			Call Subroutine(ResetCheckpoint);
			Stop Chasing Player Variable(Event Player, CurrentRunTime);
		End;
		Small Message(Event Player, Event Player.FreeMode ? Custom String("  Free mode enabled") : Custom String("  Free mode disabled"));
		Wait(0.600, Ignore Condition);
	}
}

rule("Hold [Interact] + [Ultimate] to cancel ultimate (Free Mode only)")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.FreeMode == True;
		Is Using Ultimate(Event Player) == True;
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Is Button Held(Event Player, Button(Interact)) == True;
	}

	actions
	{
		Abort If(Is True For Any(Remove From Array(Global.ButtonList, Array(Button(Ultimate), Button(Interact), Button(Jump))),
			Is Button Held(Event Player, Current Array Element)));
		Wait Until(!Is Button Held(Event Player, Button(Ultimate)), 99999);
		Call Subroutine(CancelUltimate);
		"Anti Abuse wait"
		Wait(1, Ignore Condition);
	}
}

rule("————————————————————— Effects ———————————————————————")
{
	event
	{
		Ongoing - Global;
	}
}

rule("Create Start and Finish Checkpoint rings")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
	}

	actions
	{
		Wait Until(Global.InitDone, 99999);
		"Create starting checkpoint rings"
		For Player Variable(Event Player, j, 0, Count Of(Global.Settings[0]), 1);
			Create Effect(Global.Checkpoints[Event Player.Checkpoint][5] ? Null : Event Player, Ring, Global.Settings[0][Evaluate Once(
				Event Player.j)], Global.Checkpoints[Event Player.Checkpoint][0],
				Global.Checkpoints[Event Player.Checkpoint][1] - Evaluate Once(Event Player.j * 0.200), Visible To Position Radius and Color);
		End;
		"Create goal checkpoint rings"
		For Player Variable(Event Player, j, 0, Count Of(Global.Settings[5]), 1);
			Create Effect(Global.Checkpoints[Event Player.Checkpoint + 1] ? Event Player : Null, Ring, Global.Settings[5][Evaluate Once(
				Event Player.j)], Event Player.GoalCoords, Event Player.GoalRadius - Evaluate Once(Event Player.j * 0.200),
				Visible To Position Radius and Color);
		End;
		"Create Goal checkpoint Icon"
		Create Icon(Event Player.GoalCoords ? Event Player : Null, Event Player.GoalCoords + Vector(0, 1.500, 0), Flag,
			Visible To Position and Color, Global.Settings[21], True);
		"(Alternative) Ability icon on goal"
		disabled Create In-World Text(
			Global.Checkpoints[Event Player.Checkpoint + 1] && !Global.Teleports[Event Player.Checkpoint] ? Event Player : Null,
			Ability Icon String(Hero(Brigitte), Button(Ultimate)), Event Player.GoalCoords + Vector(0, 1.500, 0), 2, Do Not Clip,
			Visible To and Position, Global.Settings[21], Default Visibility);
		"Create Goal checkpoint Text"
		Create In-World Text(Global.Checkpoints[Event Player.Checkpoint + 1] ? Event Player : Null,
			Global.Teleports[Event Player.Checkpoint] ? Global.Settings[8] : Global.Settings[7], Event Player.GoalCoords + Vector(0, 0.500,
			0), 1.500, Do Not Clip, Visible To Position and String, Global.Settings[6], Default Visibility);
		"Create Goal checkpoint effects. Light shafts dont stack"
		For Player Variable(Event Player, j, 0, Count Of(Global.Settings[16]), 1);
			Skip(Global.Settings[22] * 2);
			Create Effect(Global.Checkpoints[Event Player.Checkpoint + 1] ? Event Player : Null, Light Shaft, Evaluate Once(
				Global.Settings[16][Event Player.j]), Event Player.GoalCoords, Event Player.GoalRadius, Visible To Position Radius and Color);
			Abort;
			Create Effect(Global.Checkpoints[Event Player.Checkpoint + 1] ? Event Player : Null, Sparkles, Evaluate Once(
				Global.Settings[16][Event Player.j]), Event Player.GoalCoords, Event Player.GoalRadius, Visible To Position Radius and Color);
			Continue;
			Create Effect(Global.Checkpoints[Event Player.Checkpoint + 1] ? Event Player : Null, Cloud, Evaluate Once(
				Global.Settings[16][Event Player.j]), Event Player.GoalCoords, Event Player.GoalRadius, Visible To Position Radius and Color);
			Continue;
		End;
	}
}

rule("Create/Destroy current level Orbs")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Count Of(Event Player.OrbEffects) != Count Of(Global.Orbs[Event Player.Checkpoint]);
		Event Player.OrbEffects != Null;
	}

	actions
	{
		If(Count Of(Event Player.OrbEffects) > Count Of(Global.Orbs[Event Player.Checkpoint]));
			Destroy Effect(Last Of(Event Player.OrbEffects));
			Modify Player Variable(Event Player, OrbEffects, Remove From Array By Index, Count Of(Event Player.OrbEffects) - 1);
			Wait(0.016, Ignore Condition);
			Destroy Icon(Last Of(Event Player.OrbIcons));
			Modify Player Variable(Event Player, OrbIcons, Remove From Array By Index, Count Of(Event Player.OrbIcons) - 1);
		Else;
			"Option: Create orb effect"
			If(Global.OrbStyle == 1);
				Create Effect(Event Player.GrabbedOrbs[Evaluate Once(Count Of(Event Player.OrbEffects))] ? Null : Event Player, Orb,
					Global.Settings[1], Global.Orbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.OrbEffects))][0],
					Global.Orbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.OrbEffects))][1],
					Visible To Position Radius and Color);
			"Option: Create sphere effect"
			Else;
				Create Effect(Event Player.GrabbedOrbs[Evaluate Once(Count Of(Event Player.OrbEffects))] ? Null : Event Player, Sphere,
					Global.Settings[1], Global.Orbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.OrbEffects))][0],
					Global.Orbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.OrbEffects))][1],
					Visible To Position Radius and Color);
			End;
			"Save reference for last created orb to player variable"
			Modify Player Variable(Event Player, OrbEffects, Append To Array, Last Created Entity);
			Wait(0.016, Ignore Condition);
			"Action: Create orb icon"
			Create Icon(Event Player.GrabbedOrbs[Evaluate Once(Count Of(Event Player.OrbIcons))] ? Null : Event Player,
				Global.Orbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.OrbIcons))][0] + Vector(0,
				Global.Orbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.OrbIcons))][1] / 2, 0), Halo, Visible To and Position,
				Global.Settings[12], True);
			"Save reference for last created icon to player variable"
			Modify Player Variable(Event Player, OrbIcons, Append To Array, Last Created Entity);
		End;
		Wait(0.016, Ignore Condition);
		Loop If Condition Is True;
	}
}

rule("Create/Destroy current level RefreshOrbs")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Count Of(Event Player.RefreshOrbEffects) != Count Of(Global.RefreshOrbs[Event Player.Checkpoint]);
		Event Player.RefreshOrbEffects != Null;
	}

	actions
	{
		If(Count Of(Event Player.RefreshOrbEffects) > Count Of(Global.RefreshOrbs[Event Player.Checkpoint]));
			Destroy Effect(Last Of(Event Player.RefreshOrbEffects));
			Modify Player Variable(Event Player, RefreshOrbEffects, Remove From Array By Index, Count Of(Event Player.RefreshOrbEffects) - 1);
			Wait(0.016, Ignore Condition);
			Destroy Icon(Last Of(Event Player.RefreshOrbIcons));
			Modify Player Variable(Event Player, RefreshOrbIcons, Remove From Array By Index, Count Of(Event Player.RefreshOrbIcons) - 1);
		Else;
			"Option refresh orb with \"Orb\" effect"
			If(Global.RefreshOrbStyle == 1);
				Create Effect(Event Player.GrabbedRefreshOrbs[Evaluate Once(Count Of(Event Player.RefreshOrbEffects))] ? Null : Event Player, Orb,
					Global.Settings[4], Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.RefreshOrbEffects))][0],
					Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.RefreshOrbEffects))][1],
					Visible To Position Radius and Color);
				"Save reference for last created RefeshOrb to player variable"
				Modify Player Variable(Event Player, RefreshOrbEffects, Append To Array, Last Created Entity);
			"Create refresh orb with \"Sphere\" effect"
			Else If(Global.RefreshOrbStyle == 2);
				Create Effect(Event Player.GrabbedRefreshOrbs[Evaluate Once(Count Of(Event Player.RefreshOrbEffects))] ? Null : Event Player,
					Sphere, Global.Settings[4], Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.RefreshOrbEffects))
					][0], Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.RefreshOrbEffects))][1],
					Visible To Position Radius and Color);
				"Save reference for last created RefeshOrb to player variable"
				Modify Player Variable(Event Player, RefreshOrbEffects, Append To Array, Last Created Entity);
			"Create refresh orb with \"Cloud & Sparkles\" effect"
			Else;
				Create Effect(Event Player.GrabbedRefreshOrbs[Evaluate Once(Count Of(Event Player.RefreshOrbEffects))] ? Null : Event Player,
					Cloud, Global.Settings[4], Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.RefreshOrbEffects))
					][0], Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.RefreshOrbEffects))][1],
					Visible To Position Radius and Color);
				Event Player.Temp = Last Created Entity;
				Create Effect(Event Player.GrabbedRefreshOrbs[Evaluate Once(Count Of(Event Player.RefreshOrbEffects))] ? Null : Event Player,
					Sparkles, Global.Settings[4], Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(
					Event Player.RefreshOrbEffects))][0], Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(
					Event Player.RefreshOrbEffects))][1], Visible To Position Radius and Color);
				"Save reference for last created RefeshOrb to player variable"
				Modify Player Variable(Event Player, RefreshOrbEffects, Append To Array, Array(Array(Event Player.Temp, Last Created Entity)));
			End;
			Wait(0.016, Ignore Condition);
			"Action: Create RefeshOrb icon"
			Create Icon(Event Player.GrabbedRefreshOrbs[Evaluate Once(Count Of(Event Player.RefreshOrbIcons))] ? Null : Event Player,
				Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.RefreshOrbIcons))][0] + Vector(0,
				Global.RefreshOrbs[Event Player.Checkpoint][Evaluate Once(Count Of(Event Player.RefreshOrbIcons))][1] / 2, 0), Recycle,
				Visible To and Position, Global.Settings[13], True);
			"Save reference for last created icon to player variable"
			Modify Player Variable(Event Player, RefreshOrbIcons, Append To Array, Last Created Entity);
		End;
		Wait(0.016, Ignore Condition);
		Loop If Condition Is True;
	}
}

