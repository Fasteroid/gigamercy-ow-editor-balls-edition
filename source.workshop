		Is Dummy Bot(Event Player) == True;
		Event Player.Owner != Null;
		Array Contains(All Players(All Teams), Event Player.Owner) == False;
	}

	actions
	{
		Log To Inspector(Custom String("Destroying Orphan bot: {0}", Event Player));
		Destroy Dummy Bot(Team Of(Event Player), Slot Of(Event Player));
	}
}

rule("Resurrect Player after dying")
{
	event
	{
		Player Died;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Event Player.SpectatorMode == False;
		Event Player.Resetting == False;
	}

	actions
	{
		Log To Inspector(Custom String("{0} - died, resurrecting", Event Player));
		If(Event Player.Finished || Event Player.FreeMode);
			Teleport(Event Player, Nearest Walkable Position(Position Of(Event Player)));
		Else;
			Skip If(Event Player.Cheat, 1);
			Event Player.Mistakes += 1;
			Teleport(Event Player, Global.Checkpoints[Event Player.Checkpoint][0]);
		End;
		Resurrect(Event Player);
	}
}

