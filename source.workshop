rule("Detect Touching Jump Cloud v2")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		"Disable this to allow bots to jump on clouds"
		Is Dummy Bot(Event Player) == False;
		Global.Clouds[Event Player.Checkpoint] == True;
		disabled Event Player.FreeMode == False;
		disabled Event Player.Finished == False;
		(Altitude Of(Event Player) >= 0.030 || Is On Ground(Event Player)) == True;
		Is True For Any(Global.Clouds[Event Player.Checkpoint], Distance Between(Position Of(Event Player), Current Array Element[0])
			<= Current Array Element[1]) == True;
	}

	actions
	{
		Play Effect(Event Player, Explosion Sound, Null, Event Player, 100);
		Apply Impulse(Event Player, Up, First Of(Filtered Array(Global.Clouds[Event Player.Checkpoint], Distance Between(Position Of(
			Event Player), Current Array Element[0]) <= Current Array Element[1]))[2], To World, Cancel Contrary Motion);
	}
}

rule("Bot: Update Bot Status")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == True;
		Event Player.CallUpdate == True;
	}

	actions
	{
		Log To Inspector(Custom String("{0} - Update Status", Event Player));
		Event Player.CallUpdate = False;
		Event Player.Temp = Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection];
		"// TODO: Bots dont use ultimate yet, but killing the bot will break Mercy beam so think it through"
		If(Is Using Ultimate(Event Player));
			Kill(Event Player, Null);
		End;
		"[5]: Bot resurrect"
		If(Event Player.Temp[5]);
			Kill(Event Player, Null);
		Else;
			Resurrect(Event Player);
		End;
		"[4]: Bot gravity"
		If(Event Player.Temp[4]);
			Stop Holding Button(Event Player, Button(Jump));
			Set Gravity(Event Player, 100);
		Else;
			Set Gravity(Event Player, 0);
			Call Subroutine(CancelMomentum);
		End;
		"Teleport Bot to current level position"
		If(Count Of(Event Player.Temp) > 0);
			Set Invisible(Event Player, None);
			Teleport(Event Player, Event Player.Temp[0]);
			Wait(0.016, Ignore Condition);
		Else;
			Set Invisible(Event Player, All);
			Teleport(Event Player, Global.BotPenCoords);
		End;
		If(Event Player.Temp[3]);
			Start Holding Button(Event Player, Button(Crouch));
		Else;
			Stop Holding Button(Event Player, Button(Crouch));
		End;
		Event Player.Temp = Event Player.Temp[2];
		If(Event Player.Temp > 1);
			"Using this variable as storage for the bot facing direction"
			Event Player.GoalCoords = Event Player.Temp;
		Else;
			Event Player.GoalCoords = Event Player.Temp == 1 ? Event Player.Owner.GoalCoords : Null;
		End;
		Loop If Condition Is True;
	}
}

rule("Mercy Bot hold Jump when floating")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == True;
		Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection][4] == False;
		Is Alive(Event Player) == True;
	}

	actions
	{
		Start Holding Button(Event Player, Button(Jump));
		Wait(30, Abort When False);
		Loop If Condition Is True;
	}
}

rule("Detect Using Ability 1 v5")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Using Ability 1(Event Player) == True;
		disabled Event Player.Resetting == False;
	}

	actions
	{
		Log To Inspector(Custom String("{0} - Detected using Ability1", Event Player));
		Skip If(Event Player.FreeMode || Event Player.StartingAbilities[1] >= 7, 1);
		Event Player.Ability1 = Global.PlayerAbilityMode == 0 ? 0 : Event Player.Ability1 - 1;
		"V5: Added check for player resetting to fix a bug where mercy got an extra GA"
		Wait Until(Ability Cooldown(Event Player, Button(Ability 1)) > 0 || Event Player.Resetting, Hero Of(Event Player) == Hero(Genji)
			? 0.500 : 99999);
		Log To Inspector(Custom String("{0} - Finished using Ability 1", Event Player));
		"V5: Resetting will break the wait, SetCurrentAbilities should've handled this"
		Abort If(Event Player.Resetting);
		Set Ability 1 Enabled(Event Player, Event Player.Ability1 > 0 || Event Player.FreeMode);
	}
}

rule("Detect Using Ability 2")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Dummy Bot(Event Player) == False;
		Is Using Ability 2(Event Player) == True;
		disabled Event Player.Resetting == False;
	}

	actions
	{
		If(Hero Of(Event Player) != Hero(Mercy));
			Log To Inspector(Custom String("{0} - Detected using Ability2", Event Player));
			Skip If(Event Player.FreeMode || Event Player.StartingAbilities[2] >= 7, 1);
			Event Player.Ability2 = Global.PlayerAbilityMode == 0 ? 0 : Event Player.Ability2 - 1;
			Wait Until(Ability Cooldown(Event Player, Button(Ability 2)) > 0 || Event Player.Resetting, 99999);
			Abort If(Event Player.Resetting);
			Set Ability 2 Enabled(Event Player, Event Player.Ability2 > 0 || Event Player.FreeMode);
			Abort;
		End;
		Log To Inspector(Custom String("{0} - Detected using Mercy Rez", Event Player));
		Event Player.MercyRezTimer = 0;
		"Start chasing mercy resurrect time"
		Chase Player Variable At Rate(Event Player, MercyRezTimer, 99999, 1, None);
		Wait Until(!Is Using Ability 2(Event Player), 1.750);
		Stop Chasing Player Variable(Event Player, MercyRezTimer);
		Event Player.Ability2 = 0;
		Set Ability 2 Enabled(Event Player, Event Player.Ability2 > 0);
		Abort If(Event Player.FreeMode || Event Player.Finished);
		If(Absolute Value(Event Player.MercyRezTimer - 1.750) < 0.050);
			"Why tho?"
			disabled Resurrect(Event Player.Bot);
			"// TODO: Rework this once we allow other bot ability rewards. ?___?"
			Small Message(Event Player, Custom String("  {0} Resurrected!{1}", Global.Settings[10],
				Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection][6] ? Custom String(", {0}{1}{2} also refreshed",
				Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection][6] ? Ability Icon String(Hero Of(Event Player), Button(
				Ability 1)) : Empty Array, Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection][7] ? Ability Icon String(
				Hero Of(Event Player), Button(Ability 2)) : Empty Array,
				Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection][8] ? Ability Icon String(Hero Of(Event Player), Button(
				Ultimate)) : Empty Array) : Empty Array));
			"Resurrection refresh GA"
			Set Ability 1 Enabled(Event Player, Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection][6]);
			"Not implemented yet"
			disabled Set Ability 2 Enabled(Event Player, Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection][7]);
			"Not implemented yet"
			disabled Set Ultimate Ability Enabled(Event Player, Global.Bots[Event Player.Checkpoint][Event Player.CurrentBotSection][8]);
			Event Player.BotCondition = True;
		End;
	}
}

